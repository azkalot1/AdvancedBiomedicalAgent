# LLM provider keys (pick one provider workflow)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=your_openai_api_key_optional

# Optional tool/API keys
TAVILY_API_KEY=your_tavily_api_key_optional

# Data DB (agent tools/ingestion)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=coscientist_data
DB_USER=postgres
DB_PASSWORD=postgres
DATA_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/coscientist_data

# App DB (users + LangGraph checkpoints/store)
APP_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/coscientist_app
# Optional admin connection used only for DB creation (defaults to APP_DATABASE_URL host/user + db=postgres)
# APP_DATABASE_ADMIN_URL=postgresql://postgres:postgres@localhost:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/coscientist_app
POSTGRES_URI=postgresql://postgres:postgres@localhost:5432/coscientist_app
# Optional explicit checkpoint DB URI (defaults to POSTGRES_URI/APP_DATABASE_URL)
# BIOAGENT_CHECKPOINT_POSTGRES_URI=postgresql://postgres:postgres@localhost:5432/coscientist_app

# Agent model config
BIOAGENT_PROVIDER=openrouter
BIOAGENT_MODEL=anthropic/claude-opus-4.6
BIOAGENT_SUMMARIZER_MODEL=google/gemini-3-flash-preview
BIOAGENT_TEMPERATURE=0.5
BIOAGENT_SUMMARIZER_TEMPERATURE=0.2
# Max runtime per tool call in seconds (<=0 disables timeout)
BIOAGENT_TOOL_TIMEOUT_SECONDS=60
BIOAGENT_ASSISTANT_ID=co_scientist

# Optional API auth for /v1 endpoints
BIOAGENT_API_TOKEN=dev-token
BIOAGENT_API_USER_ID=1
BIOAGENT_AUTH_REQUIRED=false
BIOAGENT_TRUST_X_USER_ID=true

# Local server/client defaults
LANGGRAPH_API_URL=http://localhost:2024
BIOAGENT_BACKEND_URL=http://localhost:2024
NEXT_PUBLIC_BIOAGENT_ASSISTANT_ID=co_scientist
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_long_random_secret

# Research outputs (Markdown reports) root directory
BIOAGENT_RESEARCH_OUTPUT_DIR=./research_outputs
# SQLite fallback only if Postgres checkpoint init fails
BIOAGENT_CHECKPOINT_DB=.bioagent/checkpoints.db

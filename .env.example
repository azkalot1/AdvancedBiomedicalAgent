# ---------------------------
# LLM Providers + Tool APIs
# ---------------------------

# OpenRouter credentials used when BIOAGENT_PROVIDER=openrouter.
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional OpenAI-compatible provider credentials/base URL; not used, if using openrouter
OPENAI_API_KEY=your_openai_api_key_optional

# Optional Tavily key for web search tools.
TAVILY_API_KEY=your_tavily_api_key_optional


# ---------------------------
# Database Connections
# ---------------------------

# Main application database used by Aegra + auth/users + persistence fallbacks.
# Single source of truth
APP_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/coscientist_app

# Aliases — set these equal to APP_DATABASE_URL in Railway via variable references
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/coscientist_app
POSTGRES_URI=postgresql://postgres:postgres@localhost:5432/coscientist_app
AEGRA_POSTGRES_URI=postgresql://postgres:postgres@localhost:5432/coscientist_app

# Optional admin DB connection for scripts/manage_users.py init-db.
# APP_DATABASE_ADMIN_URL=postgresql://postgres:postgres@localhost:5432/postgres
# APP_DATABASE_ADMIN_DB=postgres

# Optional password fallback if DATABASE_URL omits password.
# PGPASSWORD=postgres

# Ingestion/source-data DB used by biomedagent-db ingest/setup_postgres.
DATA_POSTGRES_URI=postgresql://postgres:postgres@localhost:5432/coscientist_data

# Legacy fallback format (deprecated):
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=coscientist_data
# DB_USER=postgres
# DB_PASSWORD=postgres


# ---------------------------
# Aegra Runtime
# ---------------------------



# Redis URL used by Aegra CLI/scripts - not currently supported by Aegra
# AEGRA_REDIS_URL=redis://localhost:6379/0

# Optional Redis URI (graph runtime uses this for Aegra detection).
# AEGRA_REDIS_URI=redis://localhost:6379/0

# Optional alias mapped by scripts/run_aegra.sh when AEGRA_REDIS_URL is unset.
# REDIS_URL=redis://localhost:6379/0

# Optional explicit Aegra config path.
# AEGRA_CONFIG_PATH=./langgraph.json

# Optional default command for scripts/run_aegra.sh when no args are passed.
# AEGRA_DEFAULT_COMMAND=dev


# ---------------------------
# Agent Runtime Behavior
# ---------------------------

# Model provider + main model.
BIOAGENT_PROVIDER=openrouter
BIOAGENT_MODEL=google/gemini-3-flash-preview

# LLM sampling controls.
BIOAGENT_TEMPERATURE=0.5
BIOAGENT_SUMMARIZER_TEMPERATURE=0.2

# Tool wrapper behavior.
BIOAGENT_TOOL_TIMEOUT_SECONDS=60
BIOAGENT_STREAM_TOOL_ARGS=false

# Enable verbose LangGraph agent debug traces.
BIOAGENT_AGENT_DEBUG=false

# Graph/assistant id used by CLI and clients.
BIOAGENT_ASSISTANT_ID=co_scientist

# Optional comma-separated model presets for CLI model picker.
# BIOAGENT_PREDEFINED_MODELS=google/gemini-3-flash-preview,anthropic/claude-sonnet-4.6

# Optional defaults for CLI-scoped user/thread.
# BIOAGENT_USER_ID=1
# BIOAGENT_THREAD_ID=default

# Default runtime scope when user/thread is not provided.
BIOAGENT_DEFAULT_USER_ID=anonymous
BIOAGENT_DEFAULT_THREAD_ID=default


# ---------------------------
# Report Persistence + Checkpointing
# ---------------------------

# Optional dedicated DB for bioagent_reports table.
# If unset, falls back to AEGRA_POSTGRES_URI -> BIOAGENT_CHECKPOINT_POSTGRES_URI -> APP_DATABASE_URL -> POSTGRES_URI -> DATABASE_URL.
# BIOAGENT_RESEARCH_OUTPUT_POSTGRES_URI=postgresql://postgres:postgres@localhost:5432/coscientist_app

# Optional extra fallback DSN in report persistence resolver.
# BIOAGENT_CHECKPOINT_POSTGRES_URI=postgresql://postgres:postgres@localhost:5432/coscientist_app

# SQLite fallback — only used in local dev without Aegra. Ignored in production.
BIOAGENT_CHECKPOINT_DB=.bioagent/checkpoints.db

# Force internal checkpointer even under Aegra (normally keep false).
BIOAGENT_FORCE_INTERNAL_CHECKPOINTER=false


# ---------------------------
# API Auth + Web/API Limits
# ---------------------------

# Single bearer token auth for backend /v1 endpoints.
BIOAGENT_API_TOKEN=dev-token
BIOAGENT_API_USER_ID=1

# Optional multi-token map (JSON or token:user CSV) for /v1 auth.
# BIOAGENT_API_TOKENS={"dev-token":"1"}

# If true, rejects unauthenticated requests.
BIOAGENT_AUTH_REQUIRED=false

# If true, backend honors X-Bioagent-User-Id header from trusted proxy/frontend.
BIOAGENT_TRUST_X_USER_ID=true

# Optional report API pagination/content limits.
# BIOAGENT_REPORTS_DEFAULT_LIMIT=20
# BIOAGENT_REPORTS_MAX_LIMIT=100
# BIOAGENT_REPORTS_MAX_FETCH=2000
# BIOAGENT_REPORT_CONTENT_DEFAULT_CHARS=12000
# BIOAGENT_REPORT_CONTENT_MAX_CHARS=100000


# ---------------------------
# Frontend + Local Dev URLs
# ---------------------------

# Backend base URL used by CLI/tests.
AEGRA_API_URL=http://localhost:8000
BIOAGENT_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_BIOAGENT_BACKEND_URL=http://localhost:8000

# Frontend assistant id exposed to browser build.
NEXT_PUBLIC_BIOAGENT_ASSISTANT_ID=co_scientist

# NextAuth settings for web app.
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace_with_long_random_secret


# ---------------------------
# Stack Script Tuning (Optional)
# ---------------------------

# Wait timeout for stack start scripts.
# BIOAGENT_SERVER_WAIT_SECONDS=90

# Path for captured Aegra logs in stack scripts.
# BIOAGENT_AEGRA_LOG=.aegra/server.log

# Override web directory for stack scripts.
# BIOAGENT_WEB_DIR=./web

# Next.js dev server port used by stack scripts.
# PORT=3000
